# Dependencies
# no trailing slash: in shared-deps agent worktrees the root node_modules is
# a symlink (.husky/post-checkout), and `node_modules/` matches only real
# directories — the symlink would show up as untracked and block
# `git worktree remove`.
node_modules
.pnpm-store/

# Environment — never commit secrets. Templates (*.env.example) are kept.
.env
.env.*
!.env.example
!**/.env.example

# Next.js (apps/web)
.next/
out/
next-env.d.ts

# Sanity (apps/cms)
dist/
.sanity/
apps/cms/schema.json

# Turborepo
.turbo/

# Build / type info
*.tsbuildinfo
*.tsbuildinfo.*
.eslintcache

# Storybook
storybook-static/

# Tests / coverage
coverage/
.vitest/

# Deployment
.vercel/

# Logs
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editors / OS
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json

# Claude Code — share project config, ignore local overrides
.claude/settings.local.json
.claude/worktrees/

# superpowers subagent-driven-development scratch (progress ledger, task
# briefs, review packages) — local coordination state, never committed
.superpowers/

# Vercel CLI link scratch (env files are handled at the top of this file —
# a plain `.env*` here would override the `!.env.example` exceptions)
.vercel
