{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../configs/tsconfig/base.json",
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "noEmit": true,
    "moduleResolution": "Bundler",
    "paths": {
      "@/*": ["./src/*"],
      "@blog/ui/*": ["../../packages/ui/src/*"],
      "#/*": ["../../packages/service/src/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts",
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx"
  ],
  "exclude": ["node_modules"]
}
