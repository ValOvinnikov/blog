{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm install)",
      "Bash(pnpm add:*)",
      "Bash(pnpm --filter:*)",
      "Bash(pnpm dev:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm type-check:*)",
      "Bash(pnpm typegen:*)",
      "Bash(pnpm format:*)",
      "Bash(turbo run:*)",
      "Bash(npx sanity:*)",
      "Bash(pnpm create:*)",
      "Bash(vitest:*)",
      "Bash(pnpm storybook:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(gh project item-add:*)",
      "Bash(gh project item-edit:*)",
      "Bash(gh project item-list:*)",
      "Bash(gh project field-list:*)",
      "Bash(gh project list:*)",
      "Bash(gh label list:*)",
      "Bash(git switch:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "Bash(npm view*)",
      "Bash(pnpm knip*)",
      "mcp__plugin_context7_context7__query-docs",
      "mcp__plugin_context7_context7__resolve-library-id",
      "mcp__plugin_vercel_vercel__list_deployments",
      "mcp__claude_ai_Vercel__get_runtime_logs",
      "mcp__plugin_vercel_vercel__search_vercel_documentation",
      "mcp__claude_ai_Vercel__get_project",
      "mcp__claude_ai_Vercel__list_projects",
      "Read",
      "Edit",
      "Write",
      "Read(**/.env.example)",
      "Edit(**/.env.example)",
      "Write(**/.env.example)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.*.local)",
      "Edit(**/.env)",
      "Edit(**/.env.local)",
      "Edit(**/.env.*.local)",
      "MultiEdit(**/.env)",
      "MultiEdit(**/.env.local)",
      "MultiEdit(**/.env.*.local)",
      "Write(**/.env)",
      "Write(**/.env.local)",
      "Write(**/.env.*.local)",
      "Edit(packages/config/src/sanity/generated/**)",
      "MultiEdit(packages/config/src/sanity/generated/**)",
      "Write(packages/config/src/sanity/generated/**)",
      "Bash(cat:.env*)",
      "Bash(less:.env*)",
      "Bash(more:.env*)",
      "Bash(head:.env*)",
      "Bash(tail:.env*)",
      "Bash(bat:.env*)",
      "Bash(grep:.env*)",
      "Bash(cp *.env*)",
      "Bash(mv *.env*)",
      "Bash(printenv:*)",
      "Bash(env)",
      "Bash(pnpm --filter cms deploy:*)",
      "Bash(npx sanity deploy:*)",
      "Bash(vercel --prod:*)",
      "Bash(vercel deploy --prod:*)",
      "Bash(vercel promote:*)",
      "Bash(vercel rollback:*)",
      "mcp__plugin_vercel_vercel__deploy_to_vercel"
    ]
  },
  "extraKnownMarketplaces": {
    "claude-plugins-official": {
      "source": {
        "source": "github",
        "repo": "anthropics/claude-plugins-official"
      }
    }
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "vercel@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "sanity@claude-plugins-official": true
  },
  "worktree": {
    "baseRef": "head"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/pre-bash-worktree-install-guard.sh"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/gate-bypass-guard.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit-prettier.sh && \"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit-lint.sh"
          }
        ]
      }
    ]
  }
}
