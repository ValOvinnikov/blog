{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(pnpm install)",
      "Bash(pnpm add:*)",
      "Bash(pnpm --filter:*)",
      "Bash(pnpm dev:*)",
      "Bash(pnpm build:*)",
      "Bash(pnpm lint:*)",
      "Bash(pnpm test:*)",
      "Bash(pnpm type-check:*)",
      "Bash(pnpm typegen:*)",
      "Bash(pnpm format:*)",
      "Bash(turbo run:*)",
      "Bash(npx sanity:*)",
      "Bash(pnpm create:*)",
      "Bash(vitest:*)",
      "Bash(pnpm storybook:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(gh project item-add:*)",
      "Bash(gh project item-edit:*)",
      "Bash(gh project item-list:*)",
      "Bash(gh project field-list:*)",
      "Bash(gh project list:*)",
      "Bash(gh label list:*)",
      "Bash(git switch:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(mkdir:*)",
      "Bash(touch:*)",
      "Bash(cp:*)",
      "Bash(mv:*)",
      "mcp__plugin_context7_context7__query-docs",
      "mcp__plugin_context7_context7__resolve-library-id",
      "Read",
      "Edit",
      "Write"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Bash(cat:.env*)",
      "Bash(less:.env*)",
      "Bash(more:.env*)",
      "Bash(head:.env*)",
      "Bash(tail:.env*)",
      "Bash(bat:.env*)",
      "Bash(grep:.env*)",
      "Bash(cp *.env*)",
      "Bash(mv *.env*)",
      "Bash(printenv:*)",
      "Bash(env)",
      "Bash(pnpm --filter cms deploy:*)",
      "Bash(npx sanity deploy:*)"
    ]
  },
  "worktree": {
    "baseRef": "head"
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/post-edit-lint.sh"
          }
        ]
      }
    ]
  }
}
