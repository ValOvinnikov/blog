{
  "$schema": "https://unpkg.com/knip@6.27.0/schema.json",
  // Design specs, an HTML mockup and a reference ThemeToggle — material for
  // humans, in no workspace, never built or imported. Not source, so nothing
  // here can be "unused".
  //
  // .claude/hooks/*.js: invoked as a subprocess by its paired *.sh wrapper
  // (e.g. gate-bypass-guard.sh execs gate-bypass-guard.js), never imported
  // from TS/JS source — invisible to knip's import graph the same way the
  // *.sh hooks already are (knip doesn't scan shell files at all).
  "ignore": ["docs/design-reference/**", ".claude/hooks/*.js"],
  "workspaces": {
    "apps/cms": {
      // Each migration's default export is loaded by the Sanity CLI
      // (`sanity migrations run`), never imported from source. Listing them as
      // entries — rather than ignoring them — keeps their own imports analysed.
      // This replaces the default `{index,cli,main}` entry patterns, which match
      // nothing here; the Sanity plugin still contributes sanity.{config,cli}.ts.
      "entry": ["migrations/*/index.ts"]
    },
    "packages/service": {
      // Reachable only through a string in vitest.config.ts's `resolve.alias`,
      // which knip cannot follow. src/index.ts needs no entry of its own — it is
      // already detected from package.json `exports`.
      "entry": ["src/testing/server-only-stub.ts"]
    },
    "apps/web": {
      // The test render wrapper (customRender + RTL re-exports) is a testing
      // entry point, consumed by *.test.tsx (adoption lands in #666), not from
      // source. Mark it an entry so its exports aren't reported unused; the
      // Next.js plugin still contributes the app-router entries.
      // (packages/ui needs no such entry: its `./*` package.json export makes
      // the wrapper reachable as public API, so knip already sees it as used.)
      "entry": ["src/testing/custom-render.tsx"]
    }
  }
}
