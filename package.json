{
  "name": "blog",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "typegen": "turbo run typegen",
    "format": "turbo run format",
    "prepare": "husky"
  },
  "lint-staged": {
    "**/*.{ts,tsx,js,json,md,css}": "prettier --write"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.4.0",
    "turbo": "^2.5.0",
    "typescript": "^5.7.0"
  }
}
