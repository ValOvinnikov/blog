{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@blog/tsconfig/base.json",
  "compilerOptions": {
    "noEmit": true,
    // Declare vitest's ambient test globals explicitly (vitest config sets
    // `globals: true`) so type resolution does not depend on pnpm's hoisting
    // layout — matches @blog/ui, @blog/service, and web.
    "types": ["vitest/globals"]
  },
  "include": ["src"]
}
