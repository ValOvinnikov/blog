{
  "name": "@blog/ui",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./atoms": "./src/atoms/index.ts",
    "./molecules": "./src/molecules/index.ts",
    "./organisms": "./src/organisms/index.ts",
    "./*": "./src/*"
  },
  "scripts": {
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
