    "tailwind-variants": "^3.2.2"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@blog/eslint-config": "workspace:*",
    "@blog/prettier-config": "workspace:*",
    "@blog/tsconfig": "workspace:*",
    "@blog/vitest-config": "workspace:*",
    "@faker-js/faker": "^10.5.0",
    "@storybook/addon-essentials": "^8.6.14",
    "@storybook/addon-themes": "^8.6.14",
    "@storybook/react": "^8.6.18",
    "@storybook/react-vite": "^8.6.18",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "catalog:",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "storybook": "^8.6.18",
    "tailwindcss": "^4.3.3",
    "typescript": "catalog:",
    "vitest": "catalog:"
